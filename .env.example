# Brand Miner 环境变量配置
# 复制此文件为 .env 进行本地配置

# ═══════════════ 数据源 ═══════════════
# 可选值: tianchi / jd / mock (演示建议用 mock)
DATA_SOURCE=mock

# 天池数据集 CSV 存放目录
TIANCHI_DATA_PATH=data/real/

# 京东爬虫缓存目录
JD_CACHE_PATH=data/cache/

# 数据源不可用时是否自动降级到 Mock（建议开启）
USE_MOCK_FALLBACK=true

# ═══════════════ 数据库 ═══════════════
DATABASE_URL=sqlite+aiosqlite:///data/brand_miner.db

# ═══════════════ 服务 ═══════════════
HOST=0.0.0.0
PORT=8000

# ═══════════════ LLM (DeepSeek) ═══════════════
# 优先级：DEEPSEEK_API_KEY > LLM_API_KEY
# 模型/URL：DEEPSEEK_MODEL > LLM_MODEL, DEEPSEEK_BASE_URL > LLM_BASE_URL
# 在 .env 文件中设置，不要硬编码到代码中
DEEPSEEK_API_KEY=your-deepseek-api-key-here
LLM_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=30
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
